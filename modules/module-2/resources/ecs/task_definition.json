[
    {
        "portMappings": [
            {
                "hostPort": 80,
                "protocol": "tcp",
                "containerPort": 80
            }
        ],
        "environment": [
            {
              "name": "RDS_ENDPOINT",
              "value": "${rds_endpoint}"
            },
            {
              "name": "S3_BUCKET_NAME",
              "value": "${s3_bucket_name}"
            },
            {
            "name": "DB_PASSWORD",
            "value": "${db_password}"
            }
        ],
        "logConfiguration": {
            "logDriver": "awslogs",
            "options": {
                "awslogs-group": "${log_group}",
                "awslogs-region": "${aws_region}",
                "awslogs-stream-prefix": "ecs"
            }
        },
        "linuxParameters": {
            "capabilities": {
                "add": [
                    "SYS_PTRACE"
                ]
            },
            "initProcessEnabled": true
        },
        "cpu": 0,
        "image": "${image_uri}",
        "name": "${container_name}",
        "mountPoints": [
            {
                "sourceVolume": "modules",
                "containerPath": "/lib/modules"
            },
            {
                "sourceVolume": "kernels",
                "containerPath": "/usr/src/kernels"
            }
        ]
    }
]
