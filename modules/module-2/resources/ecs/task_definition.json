[
    {
        "portMappings": [
            {
                "hostPort": 80,
                "protocol": "tcp",
                "containerPort": 80
            }
        ],
        "environment": [
            {
              "name": "RDS_ENDPOINT",
              "value": "${rds_endpoint}"
            }
        ],
        "linuxParameters": {
            "capabilities": {
                "add": [
                    "SYS_PTRACE"
                ]
            },
            "initProcessEnabled": true
        },
        "cpu": 0,
        "image": "${image_uri}",
        "name": "${container_name}",
        "mountPoints": [
            {
                "sourceVolume": "modules",
                "containerPath": "/lib/modules"
            },
            {
                "sourceVolume": "kernels",
                "containerPath": "/usr/src/kernels"
            }
        ]
    }
]
